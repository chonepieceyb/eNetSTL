SEC("struct_ops/update")
int BPF_PROG(ss_update, struct node_base_ctx *node_ctx, struct node_base_meta *meta)
{
    int ret, hash_found;
        struct ss_map_data *ss_map = (struct ss_map_data*)meta;
        struct ss_tmp_context *context;
        int bucket_idx = -1; 
        int element_idx = -1; 
        int new_bucket_idx = -1;
        int neighbor_bucket_idx = -1; 

        bool is_last_bucket = false;
        context = (struct ss_tmp_context *)&node_ctx->mctx;
        u64 value;  // value of current bucket
        u64 neighbor_value; //value of neighbor_value
        //id 0 means the first bucket

        ret = node_base_get_root(node_ctx, BUCKETS_HEAD);
        if (ret < 0) {
                //should not happen
                log_error("failed to get  or init root, ret %d", ret);
                goto error;
        }
        hash_found = !get_node_by_hash(node_ctx, ELEMENT_IDX);
        if (!hash_found) {
                /* Step 1, case 2: Key not found and another element is replaced */
                if (ss_map->size >= SS_CAPACITY) {
                        log_debug( "replacing element as table is full and key is not found");
                        //get first element in first bucket
                        bucket_default_cmd(context);
                        ret = node_getchild_fast(node_ctx, BUCKETS_HEAD, BUCKET_IDX);
                        value = context->bucket_ctx.val;   //get value of this bucket
                        bucket_idx = BUCKET_IDX;
                        elem_default_cmd(context);
                        context->elem_ctx.write_key = true;
                        //if buckets exists, elements must exists!
                        //get list head 
                        ret = node_getchild(node_ctx, bucket_idx, BKT_ELEM_NEXT, ELEMENT_IDX);
                        element_idx = ELEMENT_IDX;
                        log_debug("replaced element key in bucket: ret %d", ret);
                } else { /* Step 1, case 3: Key not found and a new element is created */
                        log_debug("creating element as key is not found");  
                        bucket_idx = -1;
                        elem_default_cmd(context);
                        ret = alloc_new_node(node_ctx, ELEMENT_IDX);  //key set by manipulate
                        if (ret < 0) {
                                log_error("failed to alloc new element");
                                goto error;
                        }
                        element_idx = ELEMENT_IDX;
                }
        } else {
                /*hash found set bucket */
                element_idx = ELEMENT_IDX;
                bucket_default_cmd(context);
                ret = node_getchild(node_ctx, bucket_idx, ELEM_BUCKET, BUCKET_IDX);
                // if (ret < 0) {
                //         log_error("failed to get bucket from hash found element");
                //         goto error;
                // }
                value = context->bucket_ctx.val;   //get the value of this bucket
                bucket_idx = BUCKET_IDX;
        }
        /* Step 2: Find the new bucket; create if required */
        if (bucket_idx >= 0) {
                bool *is_last= (bool*)&node_ctx->mctx;
                manipulate_nodes_2_1(node_ctx, BUCKETS_HEAD, bucket_idx);
               if (!*is_last) {
                       bucket_default_cmd(context);
                       node_getchild_fast(node_ctx, bucket_idx, NEIGHBOR_BUCKET_IDX);
                       neighbor_bucket_idx = NEIGHBOR_BUCKET_IDX;
                       neighbor_value = context->bucket_ctx.val;
               } 
               log_debug("bucket value :%u, neighbor value %u", value, neighbor_value);
        } else {
                /* if the element is newly inserted, use the first bucket as "neighbor" (candidate of new bucket) */
                if (ss_map->size != 0) {
                        //the first bucket is neighbor bucket 
                        bucket_default_cmd(context);
                        node_getchild_fast(node_ctx, BUCKETS_HEAD, NEIGHBOR_BUCKET_IDX);
                        neighbor_bucket_idx = NEIGHBOR_BUCKET_IDX;
                        neighbor_value = context->bucket_ctx.val;
                }
                value = 0;   //new created value;
        }

        if (neighbor_bucket_idx >=0 && neighbor_value == value + 1) {
               log_debug( "using existing neighbor bucket: neighbor_value = %d", neighbor_value);
               new_bucket_idx = neighbor_bucket_idx;
        } else {
                log_debug("creating new bucket as the neighbor is not eligible: value %u, neighbor_idx %d, neighbor_value %u",
                        value, neighbor_bucket_idx, neighbor_value);
                //alloc new bucket
                bucket_default_cmd(context);
                context->bucket_ctx.val = value + 1;  //val set in manipulate
                ret = alloc_new_node(node_ctx, NEW_BUCKET_IDX);
                if (ret < 0) {
                        log_debug("failed to allocate new bucket");
			ret = -ENOMEM;
			goto error;
                }
                new_bucket_idx = NEW_BUCKET_IDX;
                //connect new bucket and old bucket
                if (bucket_idx >= 0 ) {
                        //add after bucket 
                        manipulate_nodes_2_2(node_ctx, bucket_idx, new_bucket_idx);
                } else {
                         //add after bucket header
                        manipulate_nodes_2_2(node_ctx, BUCKETS_HEAD, new_bucket_idx);
                }
                log_debug(
		       "created new bucket\n");
        }
        /* Step 3: Move the element from the old bucket (if exist) to the new bucket */
        if (bucket_idx >= 0) {
              log_debug("remove element from bucket and add to new bucket");
		       
              //delete node from list 
              //check list is empty if true delete bucket
              manipulate_nodes_3_1(node_ctx, bucket_idx, new_bucket_idx, element_idx); 
        } else {
              log_debug("add to new bucket");
              manipulate_nodes_2_3(node_ctx, new_bucket_idx, element_idx);
        }
        log_debug("adding element to bucket: element, new_bucket");
        /* Step4: */
        if (bucket_idx >= 0 ) {
                /**/
        }

error:
        log_error("error!");
        return -1;
}

