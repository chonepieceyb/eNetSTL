SEC("struct_ops/manipulate")
void BPF_PROG(ss_manipulate, struct node_base_ctx *node_ctx, struct node_common *node)
{
    struct ss_tmp_context *context = (struct ss_tmp_context *)&node_ctx->mctx;
    if (node_ctx->event == EVENT_GET_ROOT_ALLOC) {
        node_init_double_list_fast(node_ctx, node);
        return; 
    } else if (node_ctx->event == EVENT_GET_CHILD) {
        if (context->cmd == CMD_ROUTE_BUCKET) {
                u64 val = 0;
                node_get_val_u64(node_ctx, node, &val);
                context->bucket_ctx.val = val;
        } else {
                if (context->elem_ctx.write_key) {
                        node_write_key(node_ctx, node);
                }
        }
    } else if (node_ctx->event == EVENT_ALLOC) {
        if (context->cmd == CMD_ROUTE_ELEM) {
                node_write_key(node_ctx, node);
        } else {
                // alloc a new bucket 
                node_set_val_u64(node_ctx, node, context->bucket_ctx.val);
        }
    }
}

