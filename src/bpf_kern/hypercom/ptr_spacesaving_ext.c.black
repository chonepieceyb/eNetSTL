SEC("struct_ops/manipulate_2_1")
void BPF_PROG(ss_manipulate_2_1, struct node_base_ctx *node_ctx, struct node_common *node1, struct node_common *node2)
{
        //check bucket is last
        bool *is_last= (bool*)&node_ctx->mctx;
        *is_last = node_list_doule_is_last_fast(node_ctx, node1, node2);
}

SEC("struct_ops/manipulate_2_2")
void BPF_PROG(ss_manipulate_2_2, struct node_base_ctx *node_ctx, struct node_common *node1, struct node_common *node2)
{
    //add new bucket 
    node_list_add_double_entry_fast(node_ctx, node1, node2);
}

SEC("struct_ops/manipulate_2_3")
void BPF_PROG(ss_manipulate_2_3, struct node_base_ctx *node_ctx, struct node_common *node1, struct node_common *node2)
{
        //add elem to bucket, bucket, elem 
        node_list_double_add(node_ctx, node1, node2, BKT_ELEM_NEXT, ELEM_NEXT);
        //set element->parent = new_bucket;
        node_setchild(node_ctx, node2, ELEM_BUCKET, node1);
}

