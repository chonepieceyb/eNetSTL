int node_destory_empty_list_fast(struct node_base_ctx *node_ctx, struct node_common *head) __ksym;
int node_init_double_list_fast(struct node_base_ctx *node_ctx, struct node_common *head) __ksym;
int node_list_doule_is_last_fast(struct node_base_ctx *node_ctx, struct node_common *head, struct node_common *node) __ksym;
int node_list_doule_is_first_fast(struct node_base_ctx *node_ctx, struct node_common *head, struct node_common *node) __ksym;
int manipulate_node_1_1(struct node_base_ctx *node_ctx, u32 node_idx) __ksym;
int manipulate_node_1_2(struct node_base_ctx *node_ctx, u32 node_idx) __ksym;
int manipulate_node_1_3(struct node_base_ctx *node_ctx, u32 node_idx) __ksym;
int manipulate_node_1_4(struct node_base_ctx *node_ctx, u32 node_idx) __ksym;
int manipulate_nodes_2_1(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2) __ksym;
int manipulate_nodes_2_2(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2) __ksym;
int manipulate_nodes_2_3(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2) __ksym;
int manipulate_nodes_2_4(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2) __ksym;
int manipulate_nodes_3_1(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2, u32 node_idx3) __ksym;
int manipulate_nodes_3_2(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2, u32 node_idx3) __ksym;
int manipulate_nodes_4_1(struct node_base_ctx *node_ctx, u32 node_idx1, u32 node_idx2, u32 node_idx3, u32 node_idx4) __ksym;
int node_getchild(struct node_base_ctx *node_ctx, u32 node_idx, u32 child_idx, u32 tmp_node_idx) __ksym;
int node_getchild_fast(struct node_base_ctx *node_ctx, u32 node_idx, u32 tmp_node_idx) __ksym;
int node_base_set_root(struct node_base_ctx *node_ctx, struct node_common *node) __ksym;
int node_base_get_root(struct node_base_ctx *node_ctx, u32 node_idx) __ksym;
void node_write_key(struct node_base_ctx *node_ctx, struct node_common *node) __ksym;
void node_write_value(struct node_base_ctx *node_ctx, struct node_common *node) __ksym;
int node_compare_key(struct node_base_ctx *node_ctx, struct node_common *node) __ksym;
void node_get_val_u64(struct node_base_ctx *node_ctx, struct node_common *node, u64* res) __ksym;
void node_set_val_u64(struct node_base_ctx *node_ctx, struct node_common *node, u64 val) __ksym;
int node_check_child(struct node_base_ctx *node_ctx, struct node_common *node, u32 child_idx) __ksym;
int node_check_child_fast(struct node_common *node) __ksym;
int node_list_double_isempty(struct node_base_ctx *ctx, struct node_common *head, u32 head_next_idx) __ksym;
int node_list_double_add(struct node_base_ctx *ctx, struct node_common *head, struct node_common *new_node, u32 head_next, u32 node_next) __ksym;
int node_list_double_del(struct node_base_ctx *ctx, struct node_common *head,  u32 head_next, u32 node_next) __ksym;

struct ss_map_data {
        u32 size; // current size of data 
};

#define CMD_ROUTE_BUCKET 0
#define CMD_ROUTE_ELEM 1
#define CMD_GET_BUCKET_LIST_HEAD 2 

struct ss_tmp_context {
        int cmd;
        union {
                struct {
                        bool write_key;
                } elem_ctx;
                struct {
                        u64 val; 
                } bucket_ctx;
        };
};

#define CMD2_IS_ISLAST 0

struct ss_tmp_context2 {
        int cmd;
        bool is_last;
};

static __always_inline void bucket_default_cmd(struct ss_tmp_context *context) 
{
        context->cmd = CMD_ROUTE_BUCKET;
}

static __always_inline void elem_default_cmd(struct ss_tmp_context *context) 
{
        context->cmd = CMD_ROUTE_ELEM;
        context->elem_ctx.write_key = false;
}



/* for bucket node 
*       child 0 => next_bucket
*       child 1 => previous_bucket 
*       child 2 => first element 
*  for element node 
*       child 0 => next element 
*       child 1 => previous element 
*       child 2 => bucket
*/

#define BKT_NEXT 0
#define BKT_PREV 1
#define BKT_ELEM_NEXT 2
#define BKT_ELEM_PREV 3
#define ELEM_NEXT 0
#define ELEM_PREV 1
#define ELEM_BUCKET 2

// update 函数转换
#define BUCKETS_HEAD 0
#define ELEMENT_IDX 1 //new element or hash found element 
#define BUCKET_IDX 2
#define NEW_BUCKET_IDX 3
#define NEIGHBOR_BUCKET_IDX 4

// For user_configure
SEC("struct_ops/user_configure")
void BPF_PROG(ss_user_configure, struct node_base_user_config *config)
{
    config->child_num = 4;
}

