SEC("struct_ops/manipulate_3_1")
void BPF_PROG(ss_manipulate_3_1, struct node_base_ctx *node_ctx, struct node_common *node1, struct node_common *node2, struct node_common *node3)
{
        //bucket_idx, new_bucket_idx, element_idx
        //1. delete element from bucket_idx
        //2. check if bucket_idx is empty 
        //3. add to new_bucket 
        int is_empty;
        is_empty =  node_list_double_del(node_ctx, node1, BKT_ELEM_NEXT, ELEM_NEXT);
        if (is_empty) {
                node_list_del_double_entry_fast(node_ctx, node1);
        }
        node_list_double_add(node_ctx, node2, node3, BKT_ELEM_NEXT, ELEM_NEXT);
        //element->parent = new_bucket;
        node_setchild(node_ctx, node3, ELEM_BUCKET, node2);
}

