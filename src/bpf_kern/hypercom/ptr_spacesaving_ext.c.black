    .manipulate_1_3 = (void *)ss_manipulate_1_3,
    .manipulate_1_4 = (void *)ss_manipulate_1_4,
    .manipulate_2_1 = (void *)ss_manipulate_2_1,
    .manipulate_2_2 = (void *)ss_manipulate_2_2,
    .manipulate_2_3 = (void *)ss_manipulate_2_3,
    .manipulate_2_4 = (void *)ss_manipulate_2_4,
    .manipulate_3_1 = (void *)ss_manipulate_3_1,
    .manipulate_3_2 = (void *)ss_manipulate_3_2,
